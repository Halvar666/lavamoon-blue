<?xml version="1.0"?>

<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">

  <Description about="urn:mozilla:install-manifest">
    <em:id>lavamoonblue@palemoon-theme</em:id>
    <em:version>2.2.1</em:version>

    <!-- Target Application this extension can install into,
         with minimum and maximum supported versions. -->
    <em:targetApplication>
      <Description>
        <em:id>{8de7fcbb-c55c-4fbe-bfc5-fc555c87dbc4}</em:id>
        <em:minVersion>33.0</em:minVersion>
        <em:maxVersion>34.*</em:maxVersion>
      </Description>
    </em:targetApplication>
   
    <!-- Front End MetaData -->
    <em:name>LavaMoon Blue</em:name>
    <em:type>4</em:type>
    <em:description>Pale Moon fork/adaptation of LavaFox Blue, used with permission from the original author</em:description>
    <em:creator>Halvar666</em:creator>
    <em:contributor>Zigboom - original LavaFox / LavaFox Blue theme author</em:contributor>
    <em:unpack>true</em:unpack>

    <!-- Front End Integration Hooks (used by Theme Manager)-->
    <em:internalName>LavaMoon_Blue</em:internalName>

  </Description>     

</RDF> 